@page
@{
    ViewData["Title"] = "Contact";
}

<section class="contact-page" aria-labelledby="contactTitle">
    <div class="contact-header">
        <span class="section-eyebrow">Contact</span>
        <h1 id="contactTitle">Get help or share feedback.</h1>
        <p>
            Schema Architect is easiest to improve when feedback includes the SQL dialect,
            a small schema sample, and what you expected the generated output to look like.
        </p>
    </div>

    <div class="contact-options" aria-label="Contact options">
        <article class="contact-option">
            <span class="contact-option-label">Preferred</span>
            <h2>Open a GitHub issue</h2>
            <p>
                Use GitHub Issues for bugs, parser edge cases, feature requests, or generated code feedback.
            </p>
            <a class="contact-link" href="https://github.com/cezarpedroso/SchemaArchitect/issues" target="_blank" rel="noopener noreferrer">
                Open GitHub Issues
            </a>
        </article>

        <article class="contact-option">
            <span class="contact-option-label">Direct</span>
            <h2>Email</h2>
            <p>
                For direct questions, collaboration, or project inquiries, you can contact Cezar by email.
            </p>
            <a class="contact-link" href="mailto:cezarampedroso@proton.me">
                cezarampedroso@proton.me
            </a>
        </article>
    </div>
</section>
